<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#33181616"
    tools:context=".MainActivity">

    <androidx.cardview.widget.CardView
        android:id="@+id/card1"
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:layout_marginTop="15dp"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        app:cardCornerRadius="25dp"
        app:layout_constraintBottom_toTopOf="@id/card2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:layout_editor_absoluteX="15dp"
        app:cardElevation="8dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#212020"
            android:padding="20dp">

            <TextView
                android:id="@+id/opdetails"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text=""
                android:textAlignment="textEnd"
                android:textColor="#C1C0C0"
                android:textSize="30sp"
                app:layout_constraintBottom_toTopOf="@id/screen"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/screen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/opdetails"
                android:text="0"
                android:textAlignment="textEnd"
                android:layout_marginTop="8dp"
                android:textSize="60sp"
                android:textColor="#FFFFFF"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/card2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="15dp"
        app:cardCornerRadius="25dp"
        app:layout_constraintTop_toBottomOf="@id/card1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:cardElevation="8dp">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:columnCount="4"
            android:rowCount="5"
            android:padding="10dp">

            <Button android:id="@+id/btnclr"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="C"
                style="@style/calcbutton"
                android:background="@drawable/clrbutton_background"/>
            <Button android:id="@+id/backspace"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="⌫"
                style="@style/calcbutton"
                android:background="@drawable/opbutton_background"/>
            <Button android:id="@+id/percent"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="%"
                style="@style/calcbutton"
                android:background="@drawable/opbutton_background"/>
            <Button android:id="@+id/divide"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="÷"
                style="@style/calcbutton"
                android:background="@drawable/opbutton_background"/>
            <Button android:id="@+id/num7"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="7"
                style="@style/calcbutton"
                android:background="@drawable/numbutton_background"/>
            <Button android:id="@+id/num8"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="8"
                style="@style/calcbutton"
                android:background="@drawable/numbutton_background"/>
            <Button android:id="@+id/num9"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="9"
                style="@style/calcbutton"
                android:background="@drawable/numbutton_background"/>
            <Button android:id="@+id/mul"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="×"
                style="@style/calcbutton"
                android:background="@drawable/opbutton_background"/>
            <Button android:id="@+id/num4"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="4"
                style="@style/calcbutton"
                android:background="@drawable/numbutton_background"/>
            <Button android:id="@+id/num5"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="5"
                style="@style/calcbutton"
                android:background="@drawable/numbutton_background"/>
            <Button android:id="@+id/num6"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="6"
                style="@style/calcbutton"
                android:background="@drawable/numbutton_background"/>
            <Button android:id="@+id/minus"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="-"
                style="@style/calcbutton"
                android:background="@drawable/opbutton_background"/>
            <Button android:id="@+id/num1"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="1"
                style="@style/calcbutton"
                android:background="@drawable/numbutton_background"/>
            <Button android:id="@+id/num2"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="2"
                style="@style/calcbutton"
                android:background="@drawable/numbutton_background"/>
            <Button android:id="@+id/num3"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="3"
                style="@style/calcbutton"
                android:background="@drawable/numbutton_background"/>
            <Button android:id="@+id/plus"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="+"
                style="@style/calcbutton"
                android:background="@drawable/opbutton_background"/>
            <Button android:id="@+id/num0"
                android:layout_columnWeight="2"
                android:layout_rowWeight="1"
                android:layout_columnSpan="2"
                android:text="0"
                style="@style/calcbutton"
                android:background="@drawable/numbutton_background"/>
            <Button android:id="@+id/decimal"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="."
                style="@style/calcbutton"
                android:background="@drawable/numbutton_background"/>
            <Button android:id="@+id/equals"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:text="="
                style="@style/calcbutton"
                android:background="@drawable/equalbutton_background"/>
        </GridLayout>


    </androidx.cardview.widget.CardView>



</androidx.constraintlayout.widget.ConstraintLayout>